# CreativeOS reads the same Supabase project that CatalogStudio writes to.
# Without these set, the app runs on bundled demo data (clearly labelled).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Base URL of the CatalogStudio backend that hosts the generation queue and
# OAuth flows (Shopify / Meta connect). Leave empty if served from same origin.
VITE_API_BASE_URL=https://your-catalogstudio-app.vercel.app
